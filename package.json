{
  "name": "simplecycle",
  "version": "0.1.0",
  "description": "PWA for structured cycling workouts with a Bluetooth smart trainer",
  "private": true,
  "type": "module",
  "scripts": {
    "bump-cache": "node -e \"const fs=require('fs');const d=new Date().toISOString().slice(0,10).replace(/-/g,'');const f='sw.js';fs.writeFileSync(f,fs.readFileSync(f,'utf8').replace(/simplecycle-\\d{8}/,'simplecycle-'+d))\"",
    "start": "npx serve .",
    "test": "node --experimental-vm-modules node_modules/.bin/jest"
  },
  "devDependencies": {
    "jest": "^29.0.0",
    "sharp": "^0.34.5"
  }
}
